# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# Python
__pycache__/
*.py[cod]
venv/
.venv/
*.egg-info/

# Cython / native build artifacts.
# The .pyx sources (and their generated .c) are tracked; the compiled
# extensions are platform- and Python-version-specific, so they're rebuilt
# from source (`pip install -e . --no-deps`) rather than committed.
build/
*.pyd
*.so

# On-device verification results. Regenerable by re-running the harness, and
# the timings are specific to whichever machine produced them — the findings
# worth keeping get written up in the README instead.
app/tool/.verify_results.json
