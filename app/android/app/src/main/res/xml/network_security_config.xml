<?xml version="1.0" encoding="utf-8"?>
<!--
  Android blocks cleartext HTTP by default (API 28+). The Python backend is
  served over plain http://, so the hosts it runs on need an explicit opt-in.
  Everything else — notably huggingface.co, where GGUF weights come from —
  stays HTTPS-only under the default config.

  10.0.2.2 is the emulator's alias for the host machine's loopback, which is
  where `multi-ai-server` runs during development. To point a *physical* device
  at a backend on your LAN, add that machine's IP here as another domain entry
  and pass the same origin via the MULTI_AI_API_BASE_URL dart-define (see
  lib/api_client.dart for the exact invocation).
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
